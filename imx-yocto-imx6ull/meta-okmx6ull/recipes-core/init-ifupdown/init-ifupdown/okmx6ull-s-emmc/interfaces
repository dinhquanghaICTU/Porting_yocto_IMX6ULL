# /etc/network/interfaces -- configuration file for ifup(8), ifdown(8)

#giao dien mang ao cuc bo vd 127.0.0.1
auto lo
iface lo inet loopback

#auto up wlan lên 
#auto wlan0
#gọi dhcp xin ip tren con board này   
iface wlan0 inet dhcp
#no se chạy nen ket noi wifi co săn truoc o file wpa_supplicant.conf
    pre-up wpa_supplicant -B -i wlan0 -c /etc/wpa_supplicant/wpa_supplicant.conf
    post-down killall wpa_supplicant || true

#cai nay cung auto set up ethernet len truoc
auto eth0
#sau do no sẽ set ip tĩnh mà không xin ip tu router
iface eth0 inet static
    address 192.168.0.232
    netmask 255.255.255.0
    broadcast 192.168.0.255
